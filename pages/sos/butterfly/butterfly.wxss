/* ========================================
   蝴蝶拍 — Butterfly Hug
   Theme: Winter Solace · 暖色疗愈系
   ======================================== */

/* ---------- 页面 & 背景层 ---------- */

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 完成态腮红遮罩 */
.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(255, 251, 240, 0.25) 0%,
    rgba(252, 231, 243, 0.55) 100%
  );
  opacity: 0;
  transition: opacity 1.5s ease-in-out;
  pointer-events: none;
  z-index: 1;
}

.bg-overlay.bg-blush {
  opacity: 1;
}

/* ---------- 内容层 ---------- */

.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 40rpx;
}

/* ---------- 进度指示器 ---------- */

.set-indicator {
  position: absolute;
  top: 100rpx;
  color: var(--text-dim);
  font-family: var(--font-serif);
  font-size: 24rpx;
  letter-spacing: 6rpx;
  opacity: 0.7;
}

/* ---------- 蝴蝶容器 ---------- */

.butterfly-container {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---------- 翅膀 ---------- */

.wing {
  opacity: 0.4;
  transform: scale(0.95);
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.wing--left {
  transform-origin: right center;
}

.wing--right {
  transform-origin: left center;
}

.wing__img {
  width: 220rpx;
  display: block;
}

/* 激活态：放大 + 琥珀色发光 */
.wing.active {
  opacity: 1;
  transform: scale(1.05);
  filter: drop-shadow(0 0 24rpx rgba(251, 191, 36, 0.25));
}

/* ---------- 开始提示 ---------- */

.start-hint {
  margin-top: 60rpx;
}

.start-hint__text {
  color: var(--text-dim);
  font-family: var(--font-serif);
  font-size: 28rpx;
  letter-spacing: 6rpx;
  animation: breathe-hint 3s ease-in-out infinite;
}

@keyframes breathe-hint {
  0%, 100% { opacity: 0.35; }
  50% { opacity: 0.8; }
}

/* ---------- 引导文案 ---------- */

.intro {
  margin-top: 40rpx;
  padding: 0 60rpx;
}

.intro__text {
  font-family: var(--font-serif);
  font-size: 28rpx;
  color: var(--text-dim);
  text-align: center;
  line-height: 2.2;
  letter-spacing: 3rpx;
}

/* ---------- 节拍文字 ---------- */

.rhythm-text {
  font-family: var(--font-serif);
  font-size: 48rpx;
  color: var(--text-main);
  letter-spacing: 12rpx;
  margin-top: 50rpx;
  animation: text-fade 0.3s ease-out;
}

/* ---------- 深呼吸提示 ---------- */

.prompt {
  margin-top: 50rpx;
}

.prompt__text--breathe {
  font-family: var(--font-serif);
  font-size: 36rpx;
  letter-spacing: 8rpx;
  color: var(--text-dim);
  animation: text-fade 0.5s ease-out;
}

@keyframes text-fade {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---------- 辅助文字 ---------- */

.subtle-hint {
  position: absolute;
  bottom: 140rpx;
}

.subtle-hint__text {
  font-family: var(--font-serif);
  font-size: 22rpx;
  color: var(--text-dim);
  letter-spacing: 3rpx;
  opacity: 0.5;
}

/* ---------- 完成界面 ---------- */

.complete {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 80rpx;
  margin-top: 60rpx;
  animation: complete-enter 1.2s ease-out;
}

@keyframes complete-enter {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.complete__text {
  font-family: var(--font-serif);
  font-size: 32rpx;
  color: var(--text-main);
  text-align: center;
  line-height: 2;
  letter-spacing: 2rpx;
  font-weight: 400;
  margin-bottom: 80rpx;
}

/* ---------- 按钮组 ---------- */

.complete__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.btn {
  width: 480rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-family: var(--font-sans);
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 96rpx;
}

.btn--primary {
  background-color: var(--accent-sun);
  color: var(--text-main);
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(251, 191, 36, 0.2);
}

.btn--secondary {
  background: var(--surface);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1px solid var(--surface-border);
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.btn--ghost {
  background-color: transparent;
  color: var(--text-dim);
  font-size: 26rpx;
}
