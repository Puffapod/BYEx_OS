/* ========================================
   生理性叹息 — Physiological Sigh
   Theme: Winter Solace · 暖色疗愈系
   ======================================== */

/* ---------- 容器 & 背景过渡 ---------- */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(
    180deg,
    var(--bg) 0%,
    var(--bg-warm) 100%
  );
  overflow: hidden;
  position: relative;
  transition: background 1.5s ease-in-out;
}

/* 完成后背景过渡至腮红粉 */
.container.bg-blush {
  background: linear-gradient(
    180deg,
    var(--bg-warm) 0%,
    var(--accent-blush) 100%
  );
}

/* ---------- 轮次指示器 ---------- */

.round-indicator {
  position: absolute;
  top: 100rpx;
  color: var(--text-dim);
  font-family: var(--font-serif);
  font-size: 24rpx;
  letter-spacing: 6rpx;
  opacity: 0.7;
}

/* ---------- 呼吸光圈 ---------- */

.halo-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 600rpx;
  height: 600rpx;
  position: relative;
}

/* 外围微弱暖光环境层 */
.halo-outer-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-round);
  background: radial-gradient(
    circle,
    rgba(251, 191, 36, 0.06) 0%,
    transparent 70%
  );
  pointer-events: none;
}

/* ================================================
   暖色氤氲光晕 — Warm Ethereal Halo
   单一连续发光体，中心亮→边缘无缝消散
   渐变延伸至边界衔接 box-shadow，消除断层
   ================================================ */

.halo {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-round);

  /*
   * 渐变一直延伸到元素边界（90-100%），
   * 尾部保留低透明度衔接 box-shadow，消除中间断层
   */
  background:
    radial-gradient(circle at 48% 45%,
      rgba(254, 243, 199, 0.85) 0%,
      rgba(254, 230, 150, 0.5)  25%,
      rgba(251, 191, 36, 0.22)  50%,
      rgba(245, 180, 60, 0.1)   75%,
      rgba(245, 158, 11, 0.04)  100%),
    radial-gradient(circle at 55% 58%,
      rgba(245, 158, 11, 0.15)  0%,
      rgba(245, 158, 11, 0.06)  40%,
      rgba(245, 158, 11, 0.02)  80%,
      transparent                100%);
  opacity: 0.9;

  /* box-shadow 从元素边界向外延续发光，与渐变尾部无缝衔接 */
  box-shadow:
    inset 0 0 40rpx rgba(254, 243, 199, 0.2),
    0 0 10rpx  rgba(251, 191, 36, 0.25),
    0 0 35rpx  rgba(254, 243, 199, 0.18),
    0 0 80rpx  rgba(251, 191, 36, 0.1),
    0 0 140rpx rgba(245, 158, 11, 0.04);

  transition: width 1s ease-in-out, height 1s ease-in-out,
              box-shadow 1s ease-in-out, opacity 1s ease-in-out;
}

/* --- idle: 安静的暖光种子 --- */
.halo--idle {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.8;
  box-shadow:
    inset 0 0 30rpx rgba(254, 243, 199, 0.15),
    0 0 8rpx   rgba(251, 191, 36, 0.18),
    0 0 28rpx  rgba(254, 243, 199, 0.12),
    0 0 65rpx  rgba(251, 191, 36, 0.06),
    0 0 110rpx rgba(245, 158, 11, 0.025);
}

/* --- 吸气 1: 暖光聚合扩散 (3s) --- */
.halo--inhale1 {
  width: 400rpx;
  height: 400rpx;
  opacity: 0.95;
  box-shadow:
    inset 0 0 50rpx rgba(254, 243, 199, 0.25),
    0 0 14rpx  rgba(251, 191, 36, 0.35),
    0 0 45rpx  rgba(254, 243, 199, 0.22),
    0 0 100rpx rgba(251, 191, 36, 0.12),
    0 0 180rpx rgba(245, 158, 11, 0.05);
  transition: width 3s ease-in-out, height 3s ease-in-out,
              box-shadow 3s ease-in-out, opacity 3s ease-in-out;
}

/* --- 保持 1 --- */
.halo--hold1 {
  width: 400rpx;
  height: 400rpx;
  opacity: 0.95;
  box-shadow:
    inset 0 0 50rpx rgba(254, 243, 199, 0.25),
    0 0 14rpx  rgba(251, 191, 36, 0.35),
    0 0 45rpx  rgba(254, 243, 199, 0.22),
    0 0 100rpx rgba(251, 191, 36, 0.12),
    0 0 180rpx rgba(245, 158, 11, 0.05);
  transition: none;
}

/* --- 吸气 2: 再次聚能微扩 (0.5s) --- */
.halo--inhale2 {
  width: 460rpx;
  height: 460rpx;
  opacity: 1;
  box-shadow:
    inset 0 0 60rpx rgba(254, 243, 199, 0.3),
    0 0 18rpx  rgba(251, 191, 36, 0.42),
    0 0 55rpx  rgba(254, 243, 199, 0.28),
    0 0 120rpx rgba(251, 191, 36, 0.14),
    0 0 220rpx rgba(245, 158, 11, 0.06);
  transition: width 0.5s ease-in-out, height 0.5s ease-in-out,
              box-shadow 0.5s ease-in-out, opacity 0.5s ease-in-out;
}

/* --- 保持 2 --- */
.halo--hold2 {
  width: 460rpx;
  height: 460rpx;
  opacity: 1;
  box-shadow:
    inset 0 0 60rpx rgba(254, 243, 199, 0.3),
    0 0 18rpx  rgba(251, 191, 36, 0.42),
    0 0 55rpx  rgba(254, 243, 199, 0.28),
    0 0 120rpx rgba(251, 191, 36, 0.14),
    0 0 220rpx rgba(245, 158, 11, 0.06);
  transition: none;
}

/* --- 呼气: 暖光缓缓消散 (8s) --- */
.halo--exhale {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.8;
  box-shadow:
    inset 0 0 30rpx rgba(254, 243, 199, 0.15),
    0 0 8rpx   rgba(251, 191, 36, 0.18),
    0 0 28rpx  rgba(254, 243, 199, 0.12),
    0 0 65rpx  rgba(251, 191, 36, 0.06),
    0 0 110rpx rgba(245, 158, 11, 0.025);
  transition: width 8s ease-in-out, height 8s ease-in-out,
              box-shadow 8s ease-in-out, opacity 8s ease-in-out;
}

/* --- 完成态: 暖光安息 --- */
.halo--complete {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.5;
  box-shadow:
    inset 0 0 20rpx rgba(254, 243, 199, 0.1),
    0 0 6rpx   rgba(251, 191, 36, 0.1),
    0 0 20rpx  rgba(254, 243, 199, 0.06),
    0 0 50rpx  rgba(251, 191, 36, 0.03),
    0 0 90rpx  rgba(245, 158, 11, 0.015);
  transition: width 1.5s ease-out, height 1.5s ease-out,
              box-shadow 1.5s ease-out, opacity 1.5s ease-out;
}

/* ---------- 开始提示 ---------- */

.start-hint {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-hint__text {
  color: var(--text-dim);
  font-family: var(--font-serif);
  font-size: 28rpx;
  letter-spacing: 6rpx;
  animation: breathe-hint 3s ease-in-out infinite;
}

@keyframes breathe-hint {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.85; }
}

/* ---------- 文字提示（Serif 仪式感） ---------- */

.prompt {
  margin-top: 80rpx;
}

.prompt__text {
  font-family: var(--font-serif);
  font-size: 40rpx;
  color: var(--text-main);
  letter-spacing: 8rpx;
  font-weight: 400;
  animation: text-fade 0.5s ease-out;
}

@keyframes text-fade {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---------- 完成界面 ---------- */

.complete {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 80rpx;
  margin-top: 60rpx;
  animation: complete-enter 1.2s ease-out;
}

@keyframes complete-enter {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.complete__text {
  font-family: var(--font-serif);
  font-size: 32rpx;
  color: var(--text-main);
  text-align: center;
  line-height: 2;
  letter-spacing: 2rpx;
  font-weight: 400;
  margin-bottom: 80rpx;
}

/* ---------- 按钮组 ---------- */

.complete__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.btn {
  width: 480rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-family: var(--font-sans);
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 96rpx;
}

/* 主要按钮 — 暖阳色 */
.btn--primary {
  background-color: var(--accent-sun);
  color: var(--text-main);
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(251, 191, 36, 0.2);
}

/* 次要按钮 — 暖玻璃拟态 */
.btn--secondary {
  background: var(--surface);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1px solid var(--surface-border);
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

/* 幽灵按钮 */
.btn--ghost {
  background-color: transparent;
  color: var(--text-dim);
  font-size: 26rpx;
}
